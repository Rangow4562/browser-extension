# Azure OpenAI Configuration

# Resource/Instance name (without .openai.azure.com)
AZURE_OPENAI_API_INSTANCE_NAME=oai-ather-dev

# Deployment name (this is the name you gave to your deployment in Azure portal)
AZURE_OPENAI_API_DEPLOYMENT_NAME=

# API Key (from Azure portal)
AZURE_OPENAI_API_KEY=

# API Version
AZURE_OPENAI_API_VERSION=

# Note: The extension uses these environment variables if they are set
# Otherwise, you need to configure them in the extension settings
